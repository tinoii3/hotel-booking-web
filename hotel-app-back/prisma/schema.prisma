generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model payments {
  id             Int       @id @default(autoincrement()) @db.SmallInt
  booking_id     Int       @db.SmallInt
  amount         Float?    @db.Real
  payment_method String?   @db.VarChar
  status         String?   @db.VarChar
  pay_at         DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  booking        booking   @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model room_types {
  id              Int       @id @default(autoincrement()) @db.SmallInt
  name            String
  description     String?
  price_per_night Decimal   @db.Decimal(10, 2)
  capacity        Int?      @default(2)
  size_sqm        Int?
  amenities       Json?
  created_at      DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  rooms           rooms[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model rooms {
  id            Int             @id @default(autoincrement()) @db.SmallInt
  room_type_id  Int?            @db.SmallInt
  room_number   String          @db.VarChar
  status        String?         @default("available")
  created_at    DateTime?       @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  floor         Int?            @db.SmallInt
  staff_id      Int?            @db.SmallInt
  adults        Int?            @db.SmallInt
  children      Int?            @db.SmallInt
  booking_items booking_items[]
  room_images   room_images[]
  room_types    room_types?     @relation(fields: [room_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  staff         staff?          @relation(fields: [staff_id], references: [id], onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model staff {
  id           Int       @id @default(autoincrement()) @db.SmallInt
  position     String?
  hired_at     DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  is_active    Boolean?  @default(true)
  staff_name   String?   @db.VarChar(100)
  staff_number String?   @db.VarChar(10)
  rooms        rooms[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id             Int              @id @default(autoincrement()) @db.SmallInt
  email          String           @unique
  first_name     String?
  last_name      String?
  avatar_url     String?
  role           String?          @default("customer")
  created_at     DateTime?        @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  user_name      String           @unique @default("") @db.VarChar
  user_password  String           @default("") @db.VarChar
  booking        booking[]
  refresh_tokens refresh_tokens[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model room_images {
  id            Int       @id @default(autoincrement()) @db.SmallInt
  room_id       Int       @db.SmallInt
  image_path    String    @db.VarChar(500)
  is_cover      Boolean?  @default(false)
  display_order Int?      @default(0)
  created_at    DateTime? @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  publicId      String?
  rooms         rooms     @relation(fields: [room_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id         Int      @id @default(autoincrement()) @db.SmallInt
  user_id    Int      @db.SmallInt
  token      String   @unique
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model booking {
  id            Int             @id @default(autoincrement()) @db.SmallInt
  user_id       Int             @db.SmallInt
  check_in      DateTime?       @db.Date
  check_out     DateTime?       @db.Date
  total_price   Float?          @db.Real
  total_nights  Int?            @db.SmallInt
  total_guests  Int?            @db.SmallInt
  status        String?         @db.VarChar
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  expires_at    DateTime?       @db.Timestamptz(6)
  first_name    String?         @db.VarChar
  last_name     String?         @db.VarChar
  email         String?         @db.VarChar
  phone         String?         @db.VarChar
  note          String?         @db.VarChar
  users         users           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  booking_items booking_items[]
  payments      payments[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model booking_items {
  id              Int      @id @default(autoincrement()) @db.SmallInt
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  booking_id      Int      @db.SmallInt
  room_id         Int      @db.SmallInt
  room_name       String?
  price_per_night Float?   @db.Real
  nights          Int?     @db.SmallInt
  subtotal        Float?   @db.Real
  adults          Int?     @db.SmallInt
  children        Int?     @db.SmallInt
  booking         booking  @relation(fields: [booking_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rooms           rooms    @relation(fields: [room_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "booking_items_room_id_fkey1")
}
